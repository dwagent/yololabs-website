---
import '../styles/global.css';
interface Props { title: string; description?: string; }
const { title, description = 'YoloLabs — security engineering collective' } = Astro.props;
const nav = [
  { href: '/projects', label: 'projects' },
  { href: '/tools',    label: 'tools'    },
  { href: '/blog',     label: 'blog'     },
  { href: '/about',    label: 'about'    },
];
const current = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <title>{title === 'Home' ? 'YoloLabs' : `${title} — YoloLabs`}</title>
</head>
<body>

  <header>
    <div class="container">
      <nav>
        <a href="/" class="wordmark">[yololabs]</a>
        <ul>
          {nav.map(n => (
            <li>
              <a href={n.href} class={current.startsWith(n.href) ? 'active' : ''}>
                {n.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <div class="container">
      <span class="wordmark">[yololabs]</span>
      <span class="sep">—</span>
      <a href="mailto:hello@yololabs.org">hello@yololabs.org</a>
      <span class="sep">—</span>
      <a href="https://github.com/dwagent/yololabs-website" target="_blank" rel="noopener">github</a>
    </div>
  </footer>

</body>
</html>

<style>
  header {
    border-bottom: 1px solid var(--faint);
    padding: 0;
  }

  header .container {
    display: flex;
    align-items: center;
    height: 52px;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 2rem;
    width: 100%;
  }

  nav ul {
    display: flex;
    list-style: none;
    gap: 0.15rem;
  }

  nav ul a {
    font-size: 0.8rem;
    color: var(--muted);
    padding: 0.25rem 0.6rem;
    border-radius: 3px;
    text-decoration: none;
    transition: color 0.15s;
  }

  nav ul a:hover,
  nav ul a.active { color: var(--text); }

  .wordmark {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }

  .wordmark:hover { text-decoration: none; }

  footer {
    border-top: 1px solid var(--faint);
    margin-top: 6rem;
    padding: 1.25rem 0;
  }

  footer .container {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    color: var(--muted);
  }

  footer a { color: var(--muted); }
  footer a:hover { color: var(--text); text-decoration: none; }

  .sep { color: var(--faint); }

  @media (max-width: 480px) {
    nav ul { display: none; }
  }
</style>
