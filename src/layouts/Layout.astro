---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'YoloLabs — Security, Zero Trust, and Azure Infrastructure' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <title>{title} | YoloLabs</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <nav class="nav">
          <a href="/" class="logo">
            <span class="logo-bracket">[</span>
            <span class="logo-name">yolo</span><span class="logo-accent">labs</span>
            <span class="logo-bracket">]</span>
          </a>
          <ul class="nav-links">
            <li><a href="/projects">projects</a></li>
            <li><a href="/tools">tools</a></li>
            <li><a href="/blog">blog</a></li>
            <li><a href="/about">about</a></li>
          </ul>
          <a href="https://github.com/yololabs" class="btn btn-outline nav-cta" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            GitHub
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <span class="logo">
              <span class="logo-bracket">[</span>
              <span class="logo-name">yolo</span><span class="logo-accent">labs</span>
              <span class="logo-bracket">]</span>
            </span>
            <p>Serious security. Questionable life choices.</p>
            <p class="footer-copy">© 2026 YoloLabs. All rights reserved.</p>
          </div>
          <div class="footer-links">
            <h4>Work</h4>
            <ul>
              <li><a href="/projects">Projects</a></li>
              <li><a href="/tools">Tools</a></li>
              <li><a href="/blog">Blog</a></li>
            </ul>
          </div>
          <div class="footer-links">
            <h4>Team</h4>
            <ul>
              <li><a href="/about">About Us</a></li>
              <li><a href="mailto:hello@yololabs.org">Contact</a></li>
            </ul>
          </div>
          <div class="footer-links">
            <h4>Connect</h4>
            <ul>
              <li><a href="https://github.com/yololabs" target="_blank" rel="noopener">GitHub</a></li>
              <li><a href="https://linkedin.com" target="_blank" rel="noopener">LinkedIn</a></li>
            </ul>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 64px;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary);
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-bracket { color: var(--text-muted); }
  .logo-name    { color: var(--text-primary); }
  .logo-accent  { color: var(--accent-green); }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 0.25rem;
    flex: 1;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-secondary);
    padding: 0.35rem 0.75rem;
    border-radius: 4px;
    transition: color 0.2s, background 0.2s;
  }

  .nav-links a:hover {
    color: var(--text-primary);
    background: var(--bg-tertiary);
  }

  .nav-cta { margin-left: auto; }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: 3rem 0;
    margin-top: 4rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2rem;
  }

  .footer-brand .logo { font-size: 1rem; }

  .footer-brand p {
    margin-top: 0.75rem;
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  .footer-copy {
    margin-top: 1.5rem !important;
    color: var(--text-muted) !important;
    font-size: 0.8rem !important;
  }

  .footer-links h4 {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .footer-links ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .footer-links a:hover { color: var(--text-primary); }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
