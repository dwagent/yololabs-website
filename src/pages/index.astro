---
import Layout from '../layouts/Layout.astro';
import Terminal from '../components/Terminal.astro';

const posts = [
  { date: '2026-06-10', title: 'Why Most Zero Trust Implementations Fail', slug: 'why-zero-trust-fails' },
  { date: '2026-05-22', title: 'Building a Security-First Azure Landing Zone in 2026', slug: 'azure-landing-zone-security' },
  { date: '2026-04-15', title: 'KQL Detection Patterns That Actually Reduce Alert Fatigue', slug: 'kql-detection-patterns' },
];

const projects = [
  { name: 'enterprise-zt-framework', tags: 'zero trust · entra id',    year: '2025', href: '/projects#enterprise-zt-framework' },
  { name: 'azure-secure-alz',        tags: 'azure landing zone · bicep', year: '2025', href: '/projects#azure-secure-alz' },
  { name: 'sentinel-detections',     tags: 'microsoft sentinel · kql',  year: '2024', href: '/projects#sentinel-detections' },
  { name: 'entra-auditor',           tags: 'powershell · graph api',    year: '2024', href: '/projects#entra-auditor' },
];
---

<Layout title="Home">

  <div class="container">

    <div class="intro">
      <p class="tagline">security engineering collective.</p>
      <p class="sub">zero trust architecture, azure infrastructure, detection engineering.</p>
    </div>

    <Terminal />

    <hr />

    <section class="list-section">
      <p class="label">// recent writing</p>
      <ul class="plain-list">
        {posts.map(p => (
          <li>
            <span class="row-date">{p.date}</span>
            <a href={`/blog/${p.slug}`}>{p.title}</a>
          </li>
        ))}
      </ul>
      <a href="/blog" class="more-link">all posts →</a>
    </section>

    <hr />

    <section class="list-section">
      <p class="label">// recent work</p>
      <ul class="plain-list project-list">
        {projects.map(p => (
          <li>
            <a href={p.href} class="proj-name">{p.name}</a>
            <span class="proj-tags">{p.tags}</span>
          </li>
        ))}
      </ul>
      <a href="/projects" class="more-link">all projects →</a>
    </section>

  </div>

</Layout>

<style>
  .container { padding-top: 3rem; padding-bottom: 3rem; }

  .intro { margin-bottom: 2.5rem; }

  .tagline {
    font-size: 1rem;
    color: var(--text);
    font-weight: 500;
  }

  .sub {
    font-size: 0.82rem;
    color: var(--muted);
    margin-top: 0.2rem;
  }

  hr { margin: 3rem 0; }

  .list-section { padding: 0; }

  .label {
    color: var(--muted);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .plain-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .plain-list li {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    font-size: 0.82rem;
  }

  .row-date {
    color: var(--muted);
    flex-shrink: 0;
    font-size: 0.75rem;
  }

  .plain-list a { color: var(--text); }
  .plain-list a:hover { color: var(--blue); text-decoration: none; }

  /* project list */
  .project-list li { gap: 0; }

  .proj-name {
    min-width: 30ch;
    color: var(--blue) !important;
    flex-shrink: 0;
  }

  .proj-tags {
    color: var(--muted);
    font-size: 0.75rem;
  }

  .more-link {
    font-size: 0.75rem;
    color: var(--muted);
  }

  .more-link:hover { color: var(--text); text-decoration: none; }

  @media (max-width: 480px) {
    .project-list li { flex-direction: column; gap: 0.1rem; }
    .proj-name { min-width: unset; }
  }
</style>
