---
import Layout from '../layouts/Layout.astro';

const tools = [
  {
    id: 'entra-auditor',
    name: 'entra-auditor',
    lang: 'powershell',
    tagline: 'Find over-privileged identities, orphaned apps, and risky CA gaps in Entra ID.',
    link: 'https://github.com/yololabs/entra-auditor',
    snippet: `# install
Install-Module -Name YoloLabs.EntraAuditor

# full tenant audit (read-only, reader permissions only)
Invoke-EntraTenantAudit -OutputFormat HTML -OutputPath ./report.html`,
  },
  {
    id: 'sentinel-deploy',
    name: 'sentinel-deploy',
    lang: 'python',
    tagline: 'Deploy KQL analytic rules to Microsoft Sentinel via CI/CD.',
    link: 'https://github.com/yololabs/sentinel-deploy',
    snippet: `# deploy all rules in /rules to a sentinel workspace
python deploy.py \\
  --workspace-id $WORKSPACE_ID \\
  --resource-group $RG \\
  --rules-dir ./rules \\
  --dry-run`,
  },
  {
    id: 'azpol-lint',
    name: 'azpol-lint',
    lang: 'go',
    tagline: 'Validate Azure Policy definitions locally before deploying.',
    link: 'https://github.com/yololabs/azpol-lint',
    snippet: `# lint all policy files
azpol-lint ./policies/

# lint against a specific initiative
azpol-lint --initiative ./initiatives/cis-l1.json ./policies/`,
  },
];
---

<Layout title="Tools">
  <div class="container">

    <div class="page-header">
      <p class="label">// open source</p>
      <p class="sub">utilities we built for ourselves. mit licensed, pull requests welcome.</p>
    </div>

    <div class="tools">
      {tools.map(t => (
        <div class="tool" id={t.id}>
          <div class="tool-head">
            <div>
              <div class="tool-name-row">
                <span class="tool-name">{t.name}</span>
                <span class="tool-lang">{t.lang}</span>
              </div>
              <p class="tool-tagline">{t.tagline}</p>
            </div>
            <a href={t.link} target="_blank" rel="noopener" class="btn">github →</a>
          </div>
          <div class="snippet">
            <div class="snippet-bar">
              <span>{t.name}</span>
              <span class="snippet-lang">{t.lang}</span>
            </div>
            <pre><code>{t.snippet}</code></pre>
          </div>
        </div>
      ))}
    </div>

  </div>
</Layout>

<style>
  .container { padding-top: 3rem; padding-bottom: 3rem; }

  .page-header { margin-bottom: 2.5rem; }

  .label { font-size: 0.72rem; color: var(--muted); letter-spacing: 0.05em; margin-bottom: 0.3rem; }

  .sub { font-size: 0.8rem; color: var(--muted); }

  .tools { display: flex; flex-direction: column; gap: 2.5rem; }

  .tool {}

  .tool-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.85rem;
  }

  .tool-name-row {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    margin-bottom: 0.2rem;
  }

  .tool-name { font-size: 0.88rem; font-weight: 600; color: var(--blue); }

  .tool-lang { font-size: 0.7rem; color: var(--muted); }

  .tool-tagline { font-size: 0.78rem; color: var(--muted); }

  /* snippet */
  .snippet {
    border: 1px solid var(--faint);
    border-radius: 4px;
    overflow: hidden;
  }

  .snippet-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 1rem;
    background: var(--bg-2);
    border-bottom: 1px solid var(--faint);
    font-size: 0.72rem;
    color: var(--muted);
  }

  .snippet-lang { color: var(--faint); }

  .snippet pre {
    border: none;
    border-radius: 0;
    padding: 0.9rem 1.1rem;
    margin: 0;
    font-size: 0.78rem;
    color: var(--green);
    background: var(--bg);
    border-left: none;
  }
</style>
