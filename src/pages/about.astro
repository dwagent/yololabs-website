---
import Layout from '../layouts/Layout.astro';

const team = [
  {
    handle: 'alex',
    role: 'security architect',
    bio: 'Spent ten years designing security programs for regulated industries before deciding most of the problems were identity problems in disguise. Former CISO-adjacent. Believes the best security control is one users don\'t notice.',
    focus: ['zero trust architecture', 'identity & access management', 'security strategy'],
    certs: 'CISSP · AZ-500 · SC-100',
  },
  {
    handle: 'jordan',
    role: 'cloud infrastructure',
    bio: 'Eight years managing hybrid infrastructure before going all-in on cloud-native. Wrote the Bicep templates your team is probably using. Obsessed with policy-as-code and infrastructure that enforces its own security posture.',
    focus: ['azure landing zones', 'bicep / terraform', 'governance & compliance'],
    certs: 'AZ-104 · AZ-305 · AZ-700',
  },
  {
    handle: 'sam',
    role: 'detection engineering',
    bio: 'Came up through SOC, stayed for the hunting. Six years tuning SIEM rules and getting paged at 2am before deciding to build better detections instead of just responding to bad ones. KQL is a second language.',
    focus: ['microsoft sentinel', 'detection engineering', 'threat hunting'],
    certs: 'SC-200 · CEH · GCIA',
  },
];
---

<Layout title="About">
  <div class="container">

    <div class="page-header">
      <p class="label">// who we are</p>
    </div>

    <div class="origin">
      <p>
        YoloLabs is three security engineers and infra architects who got tired of waiting
        for someone else to fix the same problems we kept seeing everywhere.
      </p>
      <p>
        We publish the tools and write-ups we were already building on nights and weekends.
        The name is a reminder that you don't actually know what's on your network until you look.
      </p>
      <p class="tagline">"Serious security. Questionable life choices."</p>
    </div>

    <hr />

    <section>
      <p class="label">// people</p>
      <div class="team">
        {team.map(m => (
          <div class="member">
            <div class="member-head">
              <span class="handle">~/{m.handle}</span>
              <span class="role">{m.role}</span>
            </div>
            <p class="bio">{m.bio}</p>
            <div class="member-meta">
              <div class="meta-row">
                <span class="meta-label">focus</span>
                <span>{m.focus.join(' · ')}</span>
              </div>
              <div class="meta-row">
                <span class="meta-label">certs</span>
                <span class="certs">{m.certs}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <hr />

    <section class="principles">
      <p class="label">// how we work</p>
      <div class="principle-list">
        <div class="principle">
          <span class="p-label">show your work</span>
          <p>We publish methodologies, not just conclusions. If we can't explain why something is secure, it isn't.</p>
        </div>
        <div class="principle">
          <span class="p-label">automate everything repeatable</span>
          <p>Manual security processes are broken security processes.</p>
        </div>
        <div class="principle">
          <span class="p-label">write it down</span>
          <p>Architecture decisions, post-mortems, detection logic. If it's not documented, it didn't happen.</p>
        </div>
        <div class="principle">
          <span class="p-label">security enables, it doesn't block</span>
          <p>If your controls create workarounds, rethink the controls.</p>
        </div>
      </div>
    </section>

  </div>
</Layout>

<style>
  .container { padding-top: 3rem; padding-bottom: 3rem; }

  .page-header { margin-bottom: 1.5rem; }

  .label { font-size: 0.72rem; color: var(--muted); letter-spacing: 0.05em; margin-bottom: 1rem; }

  .origin {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    max-width: 62ch;
    margin-bottom: 2.5rem;
    font-size: 0.85rem;
    color: var(--text);
    line-height: 1.8;
  }

  .tagline {
    color: var(--muted);
    font-size: 0.8rem;
    padding-left: 0.75rem;
    border-left: 2px solid var(--faint);
  }

  hr { margin: 2.5rem 0; }

  /* team */
  .team {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .member { max-width: 68ch; }

  .member-head {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .handle { color: var(--green); font-size: 0.85rem; font-weight: 600; }

  .role { color: var(--muted); font-size: 0.75rem; }

  .bio { font-size: 0.82rem; color: var(--text); line-height: 1.8; margin-bottom: 0.75rem; }

  .member-meta { display: flex; flex-direction: column; gap: 0.25rem; }

  .meta-row { display: flex; gap: 1.25rem; font-size: 0.75rem; }

  .meta-label { color: var(--muted); min-width: 4ch; flex-shrink: 0; }

  .certs { color: var(--muted); }

  /* principles */
  .principle-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 62ch;
  }

  .principle { display: flex; flex-direction: column; gap: 0.2rem; }

  .p-label { font-size: 0.8rem; color: var(--blue); }

  .principle p { font-size: 0.8rem; color: var(--muted); line-height: 1.7; }
</style>
