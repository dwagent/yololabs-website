---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    id: 'enterprise-zt-framework',
    name: 'enterprise-zt-framework',
    tags: 'zero trust · identity',
    year: '2025',
    oss: false,
    summary: '1,200-user hybrid org. eliminated implicit trust zones across on-prem AD and Azure.',
    problem: 'Any device on the LAN could reach critical resources. After a near-miss ransomware incident, they needed a fundamentally different model.',
    approach: 'Identity-centric ZTA using Entra ID as the policy engine. Conditional Access policies for all cloud apps, Global Secure Access replacing legacy VPN, Intune compliance gates for device trust.',
    outcome: 'Eliminated lateral movement vectors across 23 network segments. 90-day phased rollout with zero user-impacting incidents. Attack surface reduced 67% through app-level access controls.',
    broke: 'Conditional Access rollout triggered MFA fatigue in week 2. Had to slow down, add targeted exclusions, then tighten back up. Lesson: meter the rollout — don\'t flip the switch all at once.',
    stack: ['Entra ID', 'Conditional Access', 'PIM', 'Global Secure Access', 'Intune'],
    link: null,
  },
  {
    id: 'azure-secure-alz',
    name: 'azure-secure-alz',
    tags: 'azure · iac',
    year: '2025',
    oss: true,
    summary: 'Bicep-based Azure Landing Zone with CIS benchmark compliance enforced at deploy time.',
    problem: 'Standard ALZ accelerators leave security as a post-deployment afterthought. Teams spend weeks remediating findings that should\'ve been prevented on day 0.',
    approach: 'Extended the Microsoft ALZ Bicep modules with a security overlay: custom Azure Policy initiatives for CIS Azure Foundations Benchmark, Defender for Cloud auto-provisioning, Log Analytics with 90-day retention, NSG flow logs by default.',
    outcome: 'CIS L1 compliance on day 0. Every new subscription inherits the security baseline automatically. Eliminated ~3 weeks of remediation work per environment.',
    broke: 'Azure Policy deny effects blocked a legitimate legacy workload migration in environment 3. Had to scope the deny policy to exclude specific resource groups. Blanket deny enforcement without careful scope management will burn you.',
    stack: ['Bicep', 'Azure Policy', 'Defender for Cloud', 'Log Analytics', 'GitHub Actions'],
    link: 'https://github.com/dwagent/yololabs-website',
  },
  {
    id: 'sentinel-detections',
    name: 'sentinel-detections',
    tags: 'detection · kql',
    year: '2024',
    oss: true,
    summary: '50+ production-tested KQL analytic rules covering credential attacks, lateral movement, and exfiltration. Mapped to MITRE ATT&CK.',
    problem: 'Sentinel ships with generic detection rules that generate enormous alert volumes. SOC teams spend hours triaging false positives instead of investigating real threats.',
    approach: 'Built a library of high-fidelity KQL rules tuned against real telemetry. Each rule includes MITRE ATT&CK mapping, expected false positive rate, tuning guidance, and a synthetic test case. Structured as Bicep/ARM templates for deployment-as-code.',
    outcome: 'Average false positive rate under 5% in production environments. 12 rules contributed back to the Microsoft Sentinel community. Covers 18 distinct ATT&CK techniques.',
    broke: 'Three rules that looked perfect in dev generated 400+ alerts per day in production due to a noisy data source we hadn\'t accounted for. Always test detection rules against a production data sample, not a dev workspace with clean data.',
    stack: ['KQL', 'Microsoft Sentinel', 'MITRE ATT&CK', 'Bicep', 'Python'],
    link: 'https://github.com/yololabs/sentinel-detections',
  },
  {
    id: 'entra-auditor',
    name: 'entra-auditor',
    tags: 'identity · graph api',
    year: '2024',
    oss: true,
    summary: 'PowerShell module that surfaces over-privileged identities and risky Conditional Access gaps in Entra ID.',
    problem: 'Every Entra ID tenant we\'ve audited has the same issues: service principals with Global Admin, orphaned app registrations, CA exclusions that were "temporary." They never get cleaned up.',
    approach: 'PowerShell module using Microsoft Graph API to query and analyze permissions. Outputs a prioritized risk report with remediation guidance. Read-only, no destructive operations — runs with Reader permissions.',
    outcome: 'Found 47 over-privileged service principals on first run against a production tenant. Identified 3 CA exclusion groups not reviewed in 18+ months. Now deployed as a monthly Azure Automation runbook.',
    broke: 'Graph API throttling at scale. For tenants with 10k+ objects, naive parallel requests hit rate limits immediately. Had to implement exponential backoff and batch pagination. The Graph SDK handles some of this, but not all.',
    stack: ['PowerShell', 'Microsoft Graph API', 'Entra ID', 'Azure Automation'],
    link: 'https://github.com/yololabs/entra-auditor',
  },
];
---

<Layout title="Projects">
  <div class="container">

    <div class="page-header">
      <p class="label">// our work</p>
      <p class="sub">problem → approach → outcome → what broke. in that order.</p>
    </div>

    <ul class="project-index">
      {projects.map(p => (
        <li>
          <a href={`#${p.id}`} class="idx-name">{p.name}</a>
          <span class="idx-tags">{p.tags}</span>
          <span class="idx-year">{p.year}</span>
          {p.oss && <span class="idx-oss">oss</span>}
        </li>
      ))}
    </ul>

    <hr />

    {projects.map(p => (
      <article class="project" id={p.id}>
        <div class="proj-head">
          <div>
            <h2>{p.name}</h2>
            <p class="proj-summary">{p.summary}</p>
          </div>
          {p.link && (
            <a href={p.link} target="_blank" rel="noopener" class="btn">github →</a>
          )}
        </div>

        <div class="proj-body">
          <div class="proj-row">
            <span class="row-label">problem</span>
            <p>{p.problem}</p>
          </div>
          <div class="proj-row">
            <span class="row-label">approach</span>
            <p>{p.approach}</p>
          </div>
          <div class="proj-row">
            <span class="row-label">outcome</span>
            <p>{p.outcome}</p>
          </div>
          <div class="proj-row broke">
            <span class="row-label">what broke</span>
            <p>{p.broke}</p>
          </div>
          <div class="proj-row">
            <span class="row-label">stack</span>
            <p class="stack-line">{p.stack.join(' · ')}</p>
          </div>
        </div>
      </article>
    ))}

  </div>
</Layout>

<style>
  .container { padding-top: 3rem; padding-bottom: 3rem; }

  .page-header { margin-bottom: 2rem; }

  .label { font-size: 0.72rem; color: var(--muted); letter-spacing: 0.05em; margin-bottom: 0.3rem; }

  .sub { font-size: 0.8rem; color: var(--muted); }

  /* index */
  .project-index {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 2.5rem;
  }

  .project-index li {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    font-size: 0.8rem;
  }

  .idx-name { color: var(--blue); min-width: 26ch; flex-shrink: 0; }
  .idx-name:hover { text-decoration: none; opacity: 0.8; }
  .idx-tags { color: var(--muted); flex: 1; font-size: 0.75rem; }
  .idx-year { color: var(--muted); font-size: 0.75rem; flex-shrink: 0; }
  .idx-oss  { color: var(--green); font-size: 0.7rem; flex-shrink: 0; }

  hr { margin: 2rem 0; }

  /* project detail */
  .project { margin-bottom: 3.5rem; scroll-margin-top: 4rem; }

  .proj-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .project h2 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.2rem;
  }

  .proj-summary { font-size: 0.78rem; color: var(--muted); }

  .proj-body {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    border-left: 1px solid var(--faint);
    padding-left: 1.25rem;
  }

  .proj-row { display: flex; gap: 1.5rem; font-size: 0.8rem; }

  .row-label {
    color: var(--muted);
    min-width: 9ch;
    flex-shrink: 0;
    padding-top: 0.05rem;
    font-size: 0.72rem;
    letter-spacing: 0.03em;
  }

  .proj-row p { color: var(--text); line-height: 1.75; }

  .proj-row.broke .row-label { color: var(--red); }
  .proj-row.broke p { color: var(--text); }

  .stack-line { color: var(--muted) !important; font-size: 0.75rem; }

  @media (max-width: 540px) {
    .proj-row { flex-direction: column; gap: 0.2rem; }
    .row-label { min-width: unset; }
    .project-index li { flex-wrap: wrap; }
  }
</style>
