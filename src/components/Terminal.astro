---
// Interactive terminal — no props needed
---

<div class="term" id="term">
  <div class="term-bar">
    <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
    <span class="term-title">yololabs — zsh</span>
  </div>
  <div class="term-body" id="term-body">
    <div id="term-boot">
      <div><span class="g">yololabs</span> v1.0.0 — security engineering collective</div>
      <div class="dim">────────────────────────────────────────────</div>
      <div>type <span class="g">help</span> to see available commands.</div>
      <div>&nbsp;</div>
    </div>
    <div id="term-out"></div>
    <div class="term-input-row" id="term-input-row">
      <span class="prompt">❯</span>
      <input
        id="term-input"
        type="text"
        autocomplete="off"
        autocorrect="off"
        autocapitalize="none"
        spellcheck="false"
        aria-label="terminal input"
      />
    </div>
  </div>
</div>

<style>
  .term {
    border: 1px solid var(--faint);
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg);
    cursor: text;
  }

  .term-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.6rem 1rem;
    background: var(--bg-2);
    border-bottom: 1px solid var(--faint);
  }

  .dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .dot.r { background: #e5534b; }
  .dot.y { background: #c69026; }
  .dot.g { background: #27c93f; }

  .term-title { margin-left: 0.5rem; font-size: 0.7rem; color: var(--muted); }

  .term-body {
    padding: 1.1rem 1.25rem 0.75rem;
    min-height: 260px;
    max-height: 420px;
    overflow-y: auto;
    font-size: 0.82rem;
    line-height: 1.7;
  }

  .term-input-row { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.1rem; }

  .prompt { color: var(--green); flex-shrink: 0; }

  #term-input {
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-family: var(--mono);
    font-size: 0.82rem;
    flex: 1;
    caret-color: var(--green);
    width: 100%;
  }

  .dim    { color: var(--muted); }
  .g      { color: var(--green); }
  .b      { color: var(--blue);  }
  .err    { color: var(--red);   }
  .warn   { color: var(--orange);}
  .echo   { color: var(--muted); }
  .spacer { display: block; height: 0.4rem; }
</style>

<script>
  const term      = document.getElementById('term')!;
  const termOut   = document.getElementById('term-out')!;
  const termBody  = document.getElementById('term-body')!;
  const termInput = document.getElementById('term-input') as HTMLInputElement;

  const cmdHistory: string[] = [];
  let histIdx = -1;
  let pagefindLoaded = false;

  // ── data ────────────────────────────────────────────────────────────

  const PROJECTS: Record<string, string> = {
    'enterprise-zt-framework': [
      '<span class="b">enterprise zero trust framework</span>',
      '<span class="dim">────────────────────────────────</span>',
      '',
      '<span class="dim">problem    </span>1,200-user hybrid org with implicit trust throughout the network.',
      '<span class="dim">approach   </span>identity-centric ZTA using entra id as the policy engine.',
      '<span class="dim">outcome    </span>eliminated lateral movement across 23 network segments.',
      '<span class="err">what broke </span>ca rollout triggered mfa fatigue in week 2. had to slow down.',
      '<span class="dim">stack      </span>entra id · conditional access · pim · global secure access · intune',
    ].join('\n'),
    'azure-secure-alz': [
      '<span class="b">azure secure landing zone</span>',
      '<span class="dim">────────────────────────────────</span>',
      '',
      '<span class="dim">problem    </span>standard alz leaves security as a post-deployment afterthought.',
      '<span class="dim">approach   </span>bicep overlay with cis benchmark policy + defender auto-provisioning.',
      '<span class="dim">outcome    </span>cis l1 compliance on day 0 for every new subscription.',
      '<span class="err">what broke </span>deny effects blocked a legacy workload migration. scope carefully.',
      '<span class="dim">stack      </span>bicep · azure policy · defender for cloud · log analytics',
      '<span class="g">repo       </span>github.com/dwagent/yololabs-website',
    ].join('\n'),
    'sentinel-detections': [
      '<span class="b">sentinel detection library</span>',
      '<span class="dim">────────────────────────────────</span>',
      '',
      '<span class="dim">problem    </span>generic sentinel rules → massive alert volume → analyst fatigue.',
      '<span class="dim">approach   </span>50+ high-fidelity kql rules tuned against real telemetry.',
      '<span class="dim">outcome    </span>avg false positive rate under 5% in production.',
      '<span class="err">what broke </span>3 rules generating 400+ alerts/day in prod due to noisy data source.',
      '<span class="dim">stack      </span>kql · microsoft sentinel · mitre att&ck · bicep · python',
    ].join('\n'),
    'entra-auditor': [
      '<span class="b">entra permission auditor</span>',
      '<span class="dim">────────────────────────────────</span>',
      '',
      '<span class="dim">problem    </span>every tenant has the same sprawl: over-privileged sps, orphaned apps, ca exclusions.',
      '<span class="dim">approach   </span>powershell + graph api, read-only, outputs prioritized risk report.',
      '<span class="dim">outcome    </span>found 47 over-privileged sps on first run against a production tenant.',
      '<span class="err">what broke </span>graph api throttling at scale. implemented exponential backoff.',
      '<span class="dim">stack      </span>powershell · microsoft graph api · entra id · azure automation',
    ].join('\n'),
  };

  const BLOG_POSTS = [
    { date: '2026-06-10', title: 'Why Most Zero Trust Implementations Fail', slug: 'why-zero-trust-fails' },
    { date: '2026-05-22', title: 'Building a Security-First Azure Landing Zone in 2026', slug: 'azure-landing-zone-security' },
    { date: '2026-04-15', title: 'KQL Detection Patterns That Actually Reduce Alert Fatigue', slug: 'kql-detection-patterns' },
    { date: '2026-03-28', title: 'Tackling Entra ID Permissions Sprawl at Scale', slug: 'entra-permissions-sprawl' },
  ];

  const FS_TREE = [
    'projects/   blog/   tools/   about/',
    'now/        log/',
  ];

  // ── helpers ──────────────────────────────────────────────────────────

  function esc(s: string) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function appendBlock(html: string) {
    const block = document.createElement('div');
    block.innerHTML = html;
    termOut.appendChild(block);
    const spacer = document.createElement('span');
    spacer.className = 'spacer';
    termOut.appendChild(spacer);
    termBody.scrollTop = termBody.scrollHeight;
  }

  function lines(arr: string[]) {
    return arr.map(l => `<div>${l || '&nbsp;'}</div>`).join('');
  }

  function out(text: string) {
    appendBlock(text.split('\n').map(l => `<div>${l || '&nbsp;'}</div>`).join(''));
  }

  // ── standard commands ────────────────────────────────────────────────

  const CMDS: Record<string, (args: string[]) => string | null> = {

    help: () => [
      'available commands:',
      '',
      '  <span class="g">help</span>              this message',
      '  <span class="g">whoami</span>            who we are',
      '  <span class="g">projects</span>          list projects',
      '  <span class="g">cat &lt;project&gt;</span>    project details (including what broke)',
      '  <span class="g">blog</span>              recent writing',
      '  <span class="g">search &lt;query&gt;</span>  search the site',
      '  <span class="g">contact</span>           how to reach us',
      '  <span class="g">open &lt;thing&gt;</span>    open github | linkedin | now | log',
      '  <span class="g">ls</span>                list pages',
      '  <span class="g">clear</span>             clear terminal',
    ].join('\n'),

    whoami: () => [
      'yololabs — a small collective of security engineers and infrastructure architects.',
      '',
      'we build zero trust architectures, azure landing zones,',
      'and detection engineering tooling.',
      '',
      'serious security. questionable life choices.',
    ].join('\n'),

    projects: () => {
      const rows = [
        ['enterprise-zt-framework',  'zero trust · identity',    '2025'],
        ['azure-secure-alz',         'azure · iac',              '2025', '⬡ oss'],
        ['sentinel-detections',      'detection · kql',          '2024', '⬡ oss'],
        ['entra-auditor',            'identity · graph api',     '2024'],
      ];
      return [
        '',
        ...rows.map(([name, tags, year, badge = '']) =>
          `  <span class="b">${name.padEnd(28)}</span>` +
          `<span class="dim">${tags.padEnd(24)}</span>` +
          `<span class="dim">${year}</span>` +
          (badge ? `  <span class="g">${badge}</span>` : '')
        ),
        '',
        `  <span class="dim">cat &lt;project-name&gt; for details</span>`,
        '',
      ].join('\n');
    },

    blog: () => {
      return [
        '',
        ...BLOG_POSTS.map(p =>
          `  <span class="dim">${p.date}</span>  <a href="/blog/${p.slug}" style="color:var(--blue)">${p.title}</a>`
        ),
        '',
        `  <a href="/blog" style="color:var(--muted)">→ /blog</a>  ` +
        `<a href="/now" style="color:var(--muted)">→ /now</a>  ` +
        `<a href="/log" style="color:var(--muted)">→ /log</a>`,
        '',
      ].join('\n');
    },

    ls: () => [
      '',
      `  <span class="b">projects/</span>   <span class="b">blog/</span>   <span class="b">tools/</span>   <span class="b">about/</span>`,
      `  <span class="b">now/</span>        <span class="b">log/</span>`,
      '',
    ].join('\n'),

    contact: () => [
      '',
      `  <a href="mailto:hello@yololabs.org" style="color:var(--blue)">hello@yololabs.org</a>`,
      `  <a href="https://github.com/dwagent/yololabs-website" target="_blank" style="color:var(--muted)">github.com/yololabs</a>`,
      '',
    ].join('\n'),

    open: (args) => {
      const t = args[0];
      const openTab = (url: string, label: string) => {
        window.open(url, '_blank');
        return `opening ${label}...`;
      };
      if (t === 'github')   return openTab('https://github.com/dwagent/yololabs-website', 'github.com/yololabs');
      if (t === 'linkedin') return openTab('https://linkedin.com', 'linkedin');
      if (t === 'now')      { window.location.href = '/now'; return null; }
      if (t === 'log')      { window.location.href = '/log'; return null; }
      return `<span class="err">don't know how to open: ${esc(t ?? '')}. try: open github | linkedin | now | log</span>`;
    },

  };

  // ── async search ─────────────────────────────────────────────────────

  async function runSearch(query: string) {
    if (!query.trim()) {
      out('<span class="err">usage: search &lt;query&gt;</span>');
      return;
    }
    out(`<span class="dim">searching for "${esc(query)}"...</span>`);

    try {
      if (!pagefindLoaded) {
        // @ts-ignore
        await import(/* @vite-ignore */ '/pagefind/pagefind.js');
        pagefindLoaded = true;
      }
      // @ts-ignore
      const pf = window.pagefind;
      const results = await pf.search(query);

      if (!results.results.length) {
        out(`<span class="dim">no results for "${esc(query)}"</span>`);
        return;
      }

      const data = await Promise.all(results.results.slice(0, 6).map((r: any) => r.data()));
      const resultLines = [
        `<span class="g">${data.length} result${data.length === 1 ? '' : 's'}</span>`,
        '',
        ...data.flatMap((r: any) => [
          `  <a href="${r.url}" style="color:var(--blue)">${r.meta?.title || r.url}</a>`,
          r.excerpt
            ? `  <span class="dim">${r.excerpt.replace(/<[^>]+>/g, '').slice(0, 120)}...</span>`
            : '',
          '',
        ]),
      ];
      out(resultLines.join('\n'));
    } catch {
      out('<span class="dim">search index not available in dev mode. run npm run build first.</span>');
    }
  }

  // ── command runner ───────────────────────────────────────────────────

  async function run(raw: string) {
    const trimmed = raw.trim();
    if (!trimmed) return;

    cmdHistory.unshift(trimmed);
    histIdx = -1;

    // echo
    appendBlock(`<span class="prompt">❯</span> <span class="echo">${esc(trimmed)}</span>`);

    const parts = trimmed.toLowerCase().split(/\s+/);
    const cmd   = parts[0];
    const args  = parts.slice(1);

    // specials
    if (cmd === 'clear') { termOut.innerHTML = ''; return; }

    if (cmd === 'search') { await runSearch(args.join(' ')); return; }

    if (cmd === 'cat') {
      const key = args[0];
      if (!key) { out('<span class="err">usage: cat &lt;project-name&gt;</span>'); return; }
      const detail = PROJECTS[key];
      if (detail) {
        out(detail);
      } else {
        out(`<span class="err">no such project: ${esc(key)}</span>\n<span class="dim">run 'projects' to see available names</span>`);
      }
      return;
    }

    const handler = CMDS[cmd];
    if (handler) {
      const result = handler(args);
      if (result !== null && result !== undefined) out(result);
    } else {
      out(`<span class="err">command not found: ${esc(cmd)}</span>  <span class="dim">type 'help'</span>`);
    }
  }

  // ── events ───────────────────────────────────────────────────────────

  termInput.addEventListener('keydown', async (e: KeyboardEvent) => {
    if (e.key === 'Enter') {
      const val = termInput.value;
      termInput.value = '';
      await run(val);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (histIdx < cmdHistory.length - 1) { histIdx++; termInput.value = cmdHistory[histIdx]; }
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (histIdx > 0) { histIdx--; termInput.value = cmdHistory[histIdx]; }
      else { histIdx = -1; termInput.value = ''; }
    } else if (e.key === 'Tab') {
      e.preventDefault();
      const val = termInput.value.toLowerCase().trim();
      const all = [...Object.keys(CMDS).filter(k => k !== 'whoami_root'), 'clear', 'cat', 'search'];
      const match = all.find(c => c.startsWith(val) && c !== val);
      if (match) termInput.value = match;
    }
  });

  term.addEventListener('click', () => termInput.focus());
  termInput.focus();
</script>
